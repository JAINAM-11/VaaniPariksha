# =============================================
# VaaniPariksha - Environment Configuration
# Copy this file to .env and fill in values
# =============================================

# --- Flask ---
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=your-very-secret-key-change-in-production
HOST=0.0.0.0
PORT=5000

# --- Storage Mode ---
# Set to 'local' for hackathon demo, 'aws' for production
STORAGE_MODE=local

# --- Local Database (PostgreSQL) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vaanipariksha_db
DB_USER=postgres
DB_PASSWORD=your_local_db_password

# --- AWS RDS (used when STORAGE_MODE=aws) ---
AWS_RDS_HOST=your-rds-endpoint.rds.amazonaws.com
AWS_RDS_PORT=5432
AWS_RDS_NAME=vaanipariksha_db
AWS_RDS_USER=vaanipariksha_admin
AWS_RDS_PASSWORD=your-rds-password

# --- AWS S3 ---
AWS_S3_BUCKET=vaanipariksha-pdfs
AWS_S3_REGION=ap-south-1

# --- AWS Credentials ---
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_DEFAULT_REGION=ap-south-1

# --- Vosk STT ---
VOSK_MODEL_PATH=./models_vosk/vosk-model-small-en-us-0.15
STT_CONFIDENCE_THRESHOLD=0.75

# --- TTS ---
TTS_RATE=150
TTS_VOLUME=1.0

# --- PDF Processing ---
MAX_PDF_SIZE_MB=50
UPLOAD_FOLDER=./uploads
GENERATED_PDF_FOLDER=./generated_pdfs
# Tesseract path (Windows default)
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# --- Security ---
# AES key (must be 32 bytes for AES-256 - change in production)
ENCRYPTION_KEY=VaaniPariksha2024KeyChangeInProd!

# --- Session ---
AUTO_SAVE_INTERVAL_SECONDS=30
DEFAULT_EXAM_DURATION_MINUTES=60
